# Base URL of the ADU Atlas API (FastAPI service on Render), no trailing slash.
# Used to fetch the live OpenAPI spec for /docs and live entries for /changelog.
# Leave unset in local development to fall back to the bundled OpenAPI snapshot
# and an empty-state changelog page.
NEXT_PUBLIC_API_BASE_URL=https://api.aduatlas.com

# RapidAPI listing URL for the "Get API key on RapidAPI" call-to-action shown
# throughout the portal (nav, landing, pricing).
NEXT_PUBLIC_RAPIDAPI_URL=https://rapidapi.com/adu-atlas/api/adu-atlas-api
