# Copy to .env for local runs (git-ignored). On Render these are set in the
# dashboard as sync:false env vars, not committed.

# Required - Supabase project URL and service role key.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Optional tuning (defaults shown).
SCRAPER_HEADLESS=true
SCRAPER_RATE_LIMIT_SECONDS=2
SCRAPER_MAX_SECTIONS_PER_CITY=25
SCRAPER_SAVE_SNAPSHOTS=true
# SCRAPER_SNAPSHOT_DIR=scraper/snapshots
# SCRAPER_NAV_TIMEOUT_MS=45000
# SCRAPER_SELECTOR_TIMEOUT_MS=15000
# SCRAPER_MAX_RETRIES=3
