# ADU Atlas API - full environment variable reference.
#
# This is the source of truth for every variable the system reads across all
# components (services/api, services/core, ingestion/*, portal). Per-component
# .env.example files may list a subset for convenience, but this file must stay
# complete. Copy to .env for local development:
#
#   cp .env.example .env
#
# Never commit a real .env. SUPABASE_SERVICE_ROLE_KEY and every LLM/API key
# below are secrets: set them in the environment (or the Render/Vercel
# dashboard as sync:false), never hardcode them in source.

# -----------------------------------------------------------------------------
# Supabase (Postgres 15 + PostGIS 3.3+, Storage for immutable source snapshots)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
# Service-role key: used only by services/api (server-side), ingestion/*, and
# CI. Never sent to a browser or the portal's client bundle.
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection string for services/core's PostGIS spatial joins
# and for `make migrate`. Local docker-compose default shown; Supabase CLI
# local stack uses postgresql://postgres:postgres@localhost:54322/postgres.
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54329/postgres

# -----------------------------------------------------------------------------
# LLM (offline-only: ingestion/code extraction candidates + QA cross-check.
# NEVER used on the /v1/feasibility request path.) Provide exactly one
# provider; ingestion reads Azure OpenAI first if set, otherwise Anthropic.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=

# -----------------------------------------------------------------------------
# Geocoding (address -> point, jurisdiction boundary test; spec section
# "SPATIAL / FEASIBILITY" step A). GEOCODER_PROVIDER selects the primary
# provider; the others are optional fallbacks. Census is free/keyless and is
# the default so the API works with zero geocoder keys configured.
# -----------------------------------------------------------------------------
GEOCODER_PROVIDER=census
CENSUS_GEOCODER_BASE_URL=https://geocoding.geo.census.gov/geocoder
GOOGLE_MAPS_GEOCODING_API_KEY=
MAPBOX_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# ArcGIS REST sources (public services, no key required): LA City ZIMAS
# parcels + zoning, FEMA NFHL, CAL FIRE FHSZ, CA statewide zoning bootstrap.
# These are only for local overrides during development - each has a working
# default baked into ingestion/gis/common.py, so none is required to run
# ingestion against the real public services. Variable names below match what
# ingestion/gis/common.py (Settings.from_env) actually reads; see
# ingestion/gis/README.md for the full list including layer-id overrides.
# -----------------------------------------------------------------------------
LA_ZIMAS_SERVICE_URL=https://zimas.lacity.org/arcgis/rest/services/zma/zimas/MapServer
LA_PARCEL_SERVICE_URL=
FEMA_NFHL_SERVICE_URL=https://hazards.fema.gov/arcgis/rest/services/public/NFHL/MapServer
CALFIRE_FHSZ_SERVICE_URL=https://services.gis.ca.gov/arcgis/rest/services/Environment/Fire_Severity_Zones/MapServer
CA_STATEWIDE_ZONING_SERVICE_URL=

# -----------------------------------------------------------------------------
# RapidAPI gateway (primary distribution channel; see config/plans.yaml for
# quota/plan definitions consumed by the limiter)
# -----------------------------------------------------------------------------
# Shared secret used to verify inbound requests genuinely came through the
# RapidAPI gateway (checked alongside the expected X-RapidAPI-Host / -Key
# headers, not relied on alone).
RAPIDAPI_PROXY_SECRET=
# services/api/settings.py reads RAPIDAPI_HOST (default aduatlas.p.rapidapi.com
# if unset); keep this name in sync with that default.
RAPIDAPI_HOST=aduatlas.p.rapidapi.com

# -----------------------------------------------------------------------------
# QA / alerting (ingestion/code QA cross-check worker)
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=
HCD_APR_DATASET_URL=https://data.ca.gov/dataset/housing-element-annual-progress-report-apr-data-by-jurisdiction-and-year

# -----------------------------------------------------------------------------
# services/api runtime tuning
# -----------------------------------------------------------------------------
PORT=8000
WEB_CONCURRENCY=2

# -----------------------------------------------------------------------------
# Portal (Next.js developer portal, Vercel) - client-exposed vars only; the
# service-role key above is never read by the portal.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=https://api.aduatlas.com/v1
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (only if the portal offers self-serve direct-API billing outside
# RapidAPI's own billing; RapidAPI-distributed plans are billed by RapidAPI
# and configured in config/plans.yaml, not here).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
